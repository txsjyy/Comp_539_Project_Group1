# Backend configuration for local development.
# Copy to .env or export these variables in your shell before running the Spring Boot app.

GCP_PROJECT_ID=your-gcp-project-id
GCP_BIGTABLE_INSTANCE_ID=your-bigtable-instance-id

POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_SIGNUP_TEMPLATE_ID=0
POSTMARK_RESET_PASSWORD_TEMPLATE_ID=0

APP_MAIL_FROM=noreply@example.com
APP_PRODUCT_NAME=SnapLink
APP_LOGIN_URL=http://localhost:5173/login
APP_SUPPORT_EMAIL=support@example.com
APP_LIVE_CHAT_URL=https://example.com/live-chat
APP_SENDER_NAME=SnapLink Support
APP_HELP_URL=https://example.com/help
APP_SUPPORT_URL=https://example.com/support
APP_RESET_TOKEN_EXPIRATION_HOURS=1
APP_TRIAL_LENGTH_DAYS=14

